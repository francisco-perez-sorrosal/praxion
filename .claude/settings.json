{
  "claudeMdExcludes": [
    "**/.claude/rules/ml/eval-driven-verification.md",
    "**/.claude/rules/ml/experiment-commit-conventions.md",
    "**/.claude/rules/ml/experiment-tracking-conventions.md",
    "**/.claude/rules/ml/gpu-budget-conventions.md",
    "**/.claude/rules/swe/memory-protocol.md"
  ],
  "env": {
    "PRAXION_DISABLE_MEMORY_GATE": "1",
    "PRAXION_DISABLE_MEMORY_INJECTION": "1",
    "PRAXION_DISABLE_MEMORY_MCP": "1",
    "PRAXION_DISABLE_OBSERVABILITY": "0"
  },
  "permissions": {
    "allow": [
      "Write(.ai-work/**)"
    ],
    "deny": [
      "Bash(obsidian delete --permanent*)",
      "Bash(obsidian eval*)",
      "Bash(obsidian move*)",
      "Bash(obsidian plugin:disable*)",
      "Bash(obsidian plugin:enable*)",
      "Bash(obsidian plugin:install*)",
      "Bash(obsidian plugin:uninstall*)",
      "Bash(obsidian rename*)",
      "Bash(obsidian theme:install*)",
      "Bash(obsidian theme:set*)"
    ]
  }
}
