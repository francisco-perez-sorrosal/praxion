# Hackathon Skill Loop — Environment Variables
# Copy this file to hackathon/.env and fill in real values before running.
#
# Usage: cp hackathon/.env.example hackathon/.env
# The actual .env file is gitignored (.env.*).

# =============================================================================
# Anthropic
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...   # Anthropic API key — used by run_review.py (inside sandbox), rewrite_skill.py, fix.py

# =============================================================================
# Daytona
# =============================================================================
DAYTONA_API_KEY=...                        # Daytona service API key — create at https://app.daytona.io
DAYTONA_API_URL=https://app.daytona.io    # Daytona server URL — required by DaytonaConfig(api_url=...)

# =============================================================================
# Cognee (local backends — no credentials needed)
# =============================================================================
# Cognee 1.0.3 runs an LLM/embedding connection test on every first add() call,
# even when cognify() is skipped. We skip cognify() per ADR 1, so the test is
# unnecessary work that would force a non-Anthropic dependency.
# Bypass it explicitly:
COGNEE_SKIP_CONNECTION_TEST=true

# Cognee 1.0.3 defaults to fully local, embedded backends:
#   - SQLite (relational store)
#   - LanceDB (vector store)
#   - Kuzu (graph store)
# No API key, no remote server, no account required for the default configuration.
# All data persists to disk automatically between process restarts.
#
# Optional override: set COGNEE_DB_PATH to control where Cognee stores its files.
# Uncomment and adjust if you want to relocate the data directory.
# COGNEE_DB_PATH=./hackathon/.cognee_data

# =============================================================================
# Note: OPENAI_API_KEY is intentionally absent
# =============================================================================
# This demo skips cognee.cognify() and uses SearchType.CHUNKS for retrieval only.
# Cognee's graph-build step (which calls an LLM) is not used.
# The demo runs end-to-end with Anthropic as the sole LLM provider.
# Decision: dec-draft-3abce869
