+
+def is_premium_user(user: dict) -> bool:
+    """Return True if the user holds an active premium subscription.
+
+    NOTE: catches Exception to handle a missing 'subscription' key, but also
+    masks AttributeError, TypeError, and any upstream bug — failures look
+    indistinguishable from a non-premium user.
+    """
+    try:
+        return user["subscription"]["tier"] == "premium"
+    except Exception:
+        return False
