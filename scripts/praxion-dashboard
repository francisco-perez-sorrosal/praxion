#!/usr/bin/env bash
# praxion-dashboard — Manage the Praxion Pipeline Dashboard Next.js app.
#
# One dashboard home (~/.praxion-dashboard/) is installed once per user.
# The dashboard source is synced from <praxion-root>/dashboard_app into that
# home, where pnpm dependencies, build artifacts, pidfiles, and logs live.
#
# Each project gets its own port (sha256-derived, range 8501–9500) and its
# own pidfile / logfile keyed by that port.
#
# Usage: praxion-dashboard {install|start [path]|stop [path]|restart [path]|status [path]|uninstall [--yes]}
#
# Cross-platform scope: macOS only (v1 per ADR dashboard-cross-platform-scope).
# Linux/Windows users: set PRAXION_PROJECT_ROOT and run manually after install:
#   PRAXION_PROJECT_ROOT=$(pwd) ~/.praxion-dashboard/app/node_modules/.bin/next \
#     start --hostname 127.0.0.1 --port <port>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PRAXION_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
HOME_DIR="$HOME/.praxion-dashboard"
APP_SOURCE_DIR="$PRAXION_ROOT/dashboard_app"
APP_DIR="$HOME_DIR/app"
STORE_DIR="$HOME_DIR/store"

B='\033[1m'
R='\033[0m'
info()  { printf "  \xE2\x9C\x93 %s\n" "$*"; }
warn()  { printf "  \xE2\x9A\xA0 %s\n" "$*"; }
fail()  { printf "  \xE2\x9C\x97 %s\n" "$*" >&2; exit 1; }

_is_test_mode() {
    [[ "${PRAXION_DASHBOARD_TEST_MODE:-0}" == "1" ]]
}

_require_macos() {
    if _is_test_mode; then
        return
    fi
    if [[ "$(uname -s)" != "Darwin" ]]; then
        fail "praxion-dashboard v1 requires macOS. Linux/Windows users: see header for manual-launch instructions."
    fi
}

_require_command() {
    local command_name="$1"
    if ! command -v "$command_name" >/dev/null 2>&1; then
        fail "Required command not found: $command_name"
    fi
}

_derive_port() {
    local dir="$1"
    python3 - "$dir" <<'PY'
import hashlib
import sys

abs_path = sys.argv[1].encode("utf-8")
digest = hashlib.sha256(abs_path).digest()
print(8501 + int.from_bytes(digest[:2], "big") % 1000)
PY
}

_pidfile() { echo "$HOME_DIR/$1.pid"; }
_logfile() { echo "$HOME_DIR/$1.log"; }
_next_bin() { echo "$APP_DIR/node_modules/.bin/next"; }
_build_marker() { echo "$APP_DIR/.next/BUILD_ID"; }

_is_running() {
    local port="$1"
    local pidfile
    pidfile="$(_pidfile "$port")"
    if [[ -f "$pidfile" ]]; then
        local pid
        pid=$(cat "$pidfile")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        rm -f "$pidfile"
    fi
    return 1
}

_get_pid() {
    local port="$1"
    local pidfile
    pidfile="$(_pidfile "$port")"
    if [[ -f "$pidfile" ]]; then
        local pid
        pid=$(cat "$pidfile")
        if kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
            return
        fi
    fi
}

_resolve_root_and_port() {
    local path_arg="${1:-$(pwd)}"
    [[ -d "$path_arg" ]] || fail "Project root does not exist: $path_arg"

    local root
    root="$(cd "$path_arg" && pwd -P)"
    local port
    port="${PRAXION_DASHBOARD_PORT:-$(_derive_port "$root")}"
    echo "$root $port"
}

_sync_dashboard_source() {
    [[ -d "$APP_SOURCE_DIR" ]] || fail "dashboard_app not found at $APP_SOURCE_DIR"
    _require_command rsync

    mkdir -p "$APP_DIR"
    rsync -a --delete \
        --exclude node_modules \
        --exclude .next \
        --exclude tsconfig.tsbuildinfo \
        "$APP_SOURCE_DIR/" "$APP_DIR/" >/dev/null
}

_is_installed() {
    [[ -x "$(_next_bin)" && -f "$(_build_marker)" ]]
}

_install_dashboard_app() {
    _require_command python3
    _require_command pnpm

    mkdir -p "$HOME_DIR" "$STORE_DIR"
    _sync_dashboard_source

    (
        cd "$APP_DIR"
        CI=true pnpm install --frozen-lockfile --store-dir "$STORE_DIR"
    )

    [[ -x "$(_next_bin)" ]] || fail "next binary not found after install."

    (
        cd "$APP_DIR"
        "$(_next_bin)" build
    )

    [[ -f "$(_build_marker)" ]] || fail "Next.js build did not produce .next/BUILD_ID."
}

cmd_install() {
    _require_macos
    printf "\n${B}Installing Praxion Dashboard${R}\n"

    mkdir -p "$HOME_DIR"
    info "Dashboard home: $HOME_DIR"
    info "Runtime source: $APP_SOURCE_DIR"

    printf "  Installing runtime into %s ...\n" "$APP_DIR"
    _install_dashboard_app
    info "Installation complete — run: praxion-dashboard start [project-path]"
    printf "\n"
}

cmd_start() {
    _require_macos
    local path_arg="${1:-$(pwd)}"
    read -r ROOT PORT <<< "$(_resolve_root_and_port "$path_arg")"

    local pidfile logfile
    pidfile="$(_pidfile "$PORT")"
    logfile="$(_logfile "$PORT")"
    local url="http://127.0.0.1:${PORT}"

    if _is_running "$PORT"; then
        local pid
        pid="$(_get_pid "$PORT")"
        info "Already running (PID: $pid)"
        info "Dashboard: $url"
        exit 0
    fi

    if ! _is_installed; then
        fail "Not installed. Run: praxion-dashboard install"
    fi

    printf "\n${B}Starting Praxion Dashboard${R}\n"
    printf "  Project: %s\n" "$ROOT"
    printf "  Port:    %s\n" "$PORT"

    PRAXION_PROJECT_ROOT="$ROOT" \
        "$(_next_bin)" start --hostname "127.0.0.1" --port "$PORT" \
        >> "$logfile" 2>&1 &
    local pid=$!
    echo "$pid" > "$pidfile"

    info "Dashboard starting (PID: $pid)"
    info "App: $APP_DIR"
    info "Log: $logfile"
    info "URL: $url"

    if ! _is_test_mode && [[ "$(uname -s)" == "Darwin" ]]; then
        open "$url" 2>/dev/null || true
    fi
    printf "\n"
}

cmd_stop() {
    _require_macos
    local path_arg="${1:-$(pwd)}"
    read -r ROOT PORT <<< "$(_resolve_root_and_port "$path_arg")"

    local pid
    pid="$(_get_pid "$PORT")"
    if [[ -z "$pid" ]]; then
        info "Not running (port $PORT)"
        return 0
    fi

    kill "$pid" 2>/dev/null || true
    rm -f "$(_pidfile "$PORT")"
    info "Stopped (was PID: $pid, port: $PORT)"
}

cmd_restart() {
    local path_arg="${1:-$(pwd)}"
    cmd_stop "$path_arg"
    sleep 1
    cmd_start "$path_arg"
}

cmd_status() {
    _require_macos
    local path_arg="${1:-$(pwd)}"
    read -r ROOT PORT <<< "$(_resolve_root_and_port "$path_arg")"

    printf "\n${B}Praxion Dashboard Status${R}\n"
    printf "  Project: %s\n" "$ROOT"
    printf "  Port:    %s\n" "$PORT"
    printf "  URL:     http://127.0.0.1:%s\n" "$PORT"
    printf "  Home:    %s\n" "$HOME_DIR"
    printf "  App:     %s\n" "$APP_DIR"
    printf "  Log:     %s\n" "$(_logfile "$PORT")"

    if [[ ! -d "$HOME_DIR" ]]; then
        warn "Dashboard is not installed"
        printf "\n"
        return 1
    fi

    if _is_running "$PORT"; then
        local pid
        pid="$(_get_pid "$PORT")"
        info "Running (PID: $pid)"
        local mem
        mem=$(ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.0f", $1/1024}') || true
        [[ -n "$mem" ]] && info "Memory: ${mem} MB"
        printf "\n"
        return 0
    else
        warn "Not running"
        printf "\n"
        return 1
    fi
}

cmd_uninstall() {
    _require_macos
    local yes_flag="${1:-}"

    if [[ "$yes_flag" != "--yes" ]]; then
        printf "This will remove %s and stop all running dashboards.\n" "$HOME_DIR"
        printf "Continue? [y/N] "
        read -r answer
        if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
            info "Aborted"
            return 0
        fi
    fi

    printf "\n${B}Uninstalling Praxion Dashboard${R}\n"

    local pidfile pid
    for pidfile in "$HOME_DIR"/*.pid; do
        [[ -f "$pidfile" ]] || continue
        pid=$(cat "$pidfile" 2>/dev/null) || continue
        kill "$pid" 2>/dev/null || true
        rm -f "$pidfile"
        info "Stopped PID $pid"
    done

    rm -rf "$HOME_DIR"
    info "Removed $HOME_DIR"
    printf "\n"
}

case "${1:-}" in
    install)
        cmd_install
        ;;
    start)
        cmd_start "${2:-}"
        ;;
    stop)
        cmd_stop "${2:-}"
        ;;
    restart)
        cmd_restart "${2:-}"
        ;;
    status)
        cmd_status "${2:-}"
        ;;
    uninstall)
        cmd_uninstall "${2:-}"
        ;;
    --help|-h)
        printf "Usage: praxion-dashboard {install|start [path]|stop [path]|restart [path]|status [path]|uninstall [--yes]}\n"
        printf "\nManage the Praxion Pipeline Dashboard local web application.\n\n"
        printf "Commands:\n"
        printf "  install            Sync, install, and build the dashboard runtime\n"
        printf "  start  [path]      Start dashboard for project at path (default: pwd)\n"
        printf "  stop   [path]      Stop dashboard for project at path\n"
        printf "  restart [path]     Stop + start\n"
        printf "  status  [path]     Show running status and URL\n"
        printf "  uninstall [--yes]  Stop all dashboards and remove the runtime home\n\n"
        printf "Port derivation: sha256(abs_project_path) → 8501–9500\n"
        printf "Override:        PRAXION_DASHBOARD_PORT=<port> praxion-dashboard start\n"
        printf "\nmacOS only (v1). Linux/Windows: see script header for manual launch.\n"
        ;;
    *)
        printf "Usage: praxion-dashboard {install|start [path]|stop [path]|restart [path]|status [path]|uninstall [--yes]}\n" >&2
        exit 1
        ;;
esac
