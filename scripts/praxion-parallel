#!/usr/bin/env bash
# praxion-parallel — launch N parallel Claude Code sessions across worktrees
#
# Opens N labeled, colored, isolated Claude Code sessions in either Warp
# (native Launch Configuration) or iTerm2 (AppleScript). Each session runs
# `claude --worktree <name>`, so Claude Code itself owns worktree creation
# and cleanup. This script does not call `git worktree add`.
#
# Usage:
#   praxion-parallel [PROJECT] [OPTIONS]
#   praxion-parallel --help
#
# Why exists:
#   - `scripts/ccwt` (deprecated, removed) was tmux-only and limited to
#     existing worktrees. Multi-session work on a modern macOS dev box
#     wants the native terminal (Warp tabs / iTerm2 tabs), per-tab color
#     for cognitive separation, and on-demand worktree creation.
#   - `scripts/dispatch-reworks` is the *verifier-loop* dispatcher. It
#     parses REWORK_MANIFEST.md and is wired into hooks/notifications.
#     This script is its generic peer for non-rework parallel work.

set -eo pipefail

# ----------------------------------------------------------------------------
# Constants
# ----------------------------------------------------------------------------

readonly SELF_NAME="praxion-parallel"
readonly MAX_SESSIONS=6
readonly DEFAULT_SESSIONS=2
readonly DEV_DIR="${PRAXION_DEV_DIR:-$HOME/dev}"
readonly WARP_LC_DIR="${HOME}/.warp/launch_configurations"

# Warp supports these ANSI tab colors (verified against docs.warp.dev).
readonly WARP_COLORS=(red green yellow blue magenta cyan)

# iTerm2 OSC 6 tab color uses RGB; values chosen to roughly match the
# Warp palette for cross-backend visual parity.
readonly ITERM_RGB=(
    "200;30;30"     # red
    "30;180;60"     # green
    "210;180;30"    # yellow
    "40;100;220"    # blue
    "180;60;200"    # magenta
    "30;180;200"    # cyan
)

# Exit codes
readonly EXIT_OK=0
readonly EXIT_USAGE=2
readonly EXIT_PROJECT=3
readonly EXIT_TERMINAL=4
readonly EXIT_SPAWN=5

# ----------------------------------------------------------------------------
# Output helpers
# ----------------------------------------------------------------------------

if [ -t 1 ]; then
    B=$'\033[1m'; D=$'\033[2m'; Y=$'\033[33m'; R=$'\033[0m'
else
    B=''; D=''; Y=''; R=''
fi

die() { printf "%s: %s\n" "$SELF_NAME" "$*" >&2; exit "${EXIT_CODE:-1}"; }
info() { printf "  %s\n" "$*"; }
warn() { printf "  ${Y}⚠ %s${R}\n" "$*" >&2; }
step() { printf "    %s\n" "$*"; }

show_usage() {
    cat <<EOF
${B}Usage:${R} $SELF_NAME [PROJECT] [OPTIONS]
       $SELF_NAME --help

Launch N parallel Claude Code sessions in Warp or iTerm2, each in its own
git worktree (via \`claude --worktree\`), each visually distinguished by
tab color and title.

${B}ARGUMENT${R}
  PROJECT                  Project directory. One of:
                             - absolute path (/path/to/proj)
                             - relative-with-slash (./proj)
                             - bare name (proj) → \$PRAXION_DEV_DIR/proj
                                                  (default \$HOME/dev/proj)
                           Default: current working directory.

${B}OPTIONS${R}
  -n, --count N            Number of sessions to launch.
                           Default ${DEFAULT_SESSIONS}, max ${MAX_SESSIONS}.
  -t, --terminal T         warp (default) | iterm2
  -y, --yolo               Pass --dangerously-skip-permissions to each
                           session. Loud warning printed.
  -w, --worktrees MODE     new (default) | existing | none
                             - new: \`claude --worktree s1\` ... \`sN\` (or
                                    names from --names); Claude Code creates
                                    each worktree under .claude/worktrees/
                             - existing: discover via git worktree list,
                                    one session per existing worktree
                             - none: all sessions in project root (no
                                    isolation; warning printed)
      --names a,b,c        Explicit worktree names (overrides --count).
      --base-ref REF       fresh (default) | head — applied via the worktree
                           settings overlay (see docs/worktree-baseref-default).
      --tasks "T1|T2|..."  Per-session initial prompts; pipe-separated; one
                           pre-typed in each session (user presses Enter).
      --append-system-prompts "P1|P2|..."
                           Per-session --append-system-prompt; pipe-separated.
                           Pair with --tasks for recipe-style role assignments.
      --yolos "t,f,t,..."  Per-session --dangerously-skip-permissions overrides
                           (comma-separated booleans: t/true/1 or f/false/0).
                           Overrides --yolo when set per-session.
      --ui [PROJECT]       Launch the ephemeral web launcher instead of
                           spawning directly. Submits compose into this script.
      --layout LAYOUT      tabs (default) | windows | panes
                             - tabs:    one window, N tabs
                             - windows: N separate windows, one session each
                             - panes:   one window, one tab, N rectangular
                                        split panes. Capped at N=4 (max useful
                                        density without overlap).
      --warp-mode MODE     launch-config (default) | tabs
                             - launch-config: write YAML + open warp://launch/.
                               Autonomous BUT subject to upstream Warp bug
                               #9007 (commands silently dropped via URL launch).
                             - tabs: open one warp://action/new_tab?path= per
                               tab. Reliably opens N tabs at the right cwd;
                               the claude command is printed for you to paste.
      --keep-config        Preserve the generated Warp Launch Config YAML
                           (default: deleted 30s after launch).
      --dry-run            Print the spawn plan; do not launch.
      --list               List existing worktrees in PROJECT and exit.
  -h, --help               Show this help.

${B}EXAMPLES${R}
  # 3 sessions in 3 fresh worktrees in the current project, Warp, auto-approve
  $SELF_NAME -n 3 -y

  # iTerm2, named worktrees, per-session task instructions
  $SELF_NAME -t iterm2 \\
      --names auth,billing,docs \\
      --tasks "implement OAuth|fix billing race|update README"

  # Attach to all existing worktrees of \$HOME/dev/foo
  $SELF_NAME foo --worktrees existing

  # Preview before launching
  $SELF_NAME -n 4 --dry-run

${B}NOTES${R}
  - Each session uses \`claude --worktree <name>\`. Claude Code creates and
    cleans up the worktree. .worktreeinclude in the project root copies
    .env-style files into each worktree automatically.
  - 2-3 sessions is the practical ceiling for most people; --count caps at
    ${MAX_SESSIONS}.
  - Warp launch configs are written to ${WARP_LC_DIR/$HOME/~}/
    and removed after launch unless an error prevents it.

EOF
    exit "$EXIT_OK"
}

# ----------------------------------------------------------------------------
# Argument parsing
# ----------------------------------------------------------------------------

PROJECT_ARG=""
COUNT=""
TERMINAL="warp"
YOLO=false
WORKTREES="new"
NAMES_CSV=""
BASE_REF=""
TASKS_PIPED=""
SYSPROMPTS_PIPED=""
YOLOS_CSV=""
LAYOUT="tabs"
USE_UI=false
WARP_MODE="launch-config"
KEEP_CONFIG=false
NO_COLOR=false
DRY_RUN=false
LIST_ONLY=false

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help) show_usage ;;
        -n|--count)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--count needs a value"; }
            COUNT="$2"; shift ;;
        --count=*) COUNT="${1#--count=}" ;;
        -t|--terminal)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--terminal needs a value"; }
            TERMINAL="$2"; shift ;;
        --terminal=*) TERMINAL="${1#--terminal=}" ;;
        -y|--yolo) YOLO=true ;;
        -w|--worktrees)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--worktrees needs a value"; }
            WORKTREES="$2"; shift ;;
        --worktrees=*) WORKTREES="${1#--worktrees=}" ;;
        --names)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--names needs a value"; }
            NAMES_CSV="$2"; shift ;;
        --names=*) NAMES_CSV="${1#--names=}" ;;
        --base-ref)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--base-ref needs a value"; }
            BASE_REF="$2"; shift ;;
        --base-ref=*) BASE_REF="${1#--base-ref=}" ;;
        --tasks)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--tasks needs a value"; }
            TASKS_PIPED="$2"; shift ;;
        --tasks=*) TASKS_PIPED="${1#--tasks=}" ;;
        --append-system-prompts)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--append-system-prompts needs a value"; }
            SYSPROMPTS_PIPED="$2"; shift ;;
        --append-system-prompts=*) SYSPROMPTS_PIPED="${1#--append-system-prompts=}" ;;
        --yolos)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--yolos needs a value"; }
            YOLOS_CSV="$2"; shift ;;
        --yolos=*) YOLOS_CSV="${1#--yolos=}" ;;
        --ui) USE_UI=true ;;
        --layout)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--layout needs a value"; }
            LAYOUT="$2"; shift ;;
        --layout=*) LAYOUT="${1#--layout=}" ;;
        --warp-mode)
            [ -z "${2:-}" ] && { EXIT_CODE=$EXIT_USAGE die "--warp-mode needs a value"; }
            WARP_MODE="$2"; shift ;;
        --warp-mode=*) WARP_MODE="${1#--warp-mode=}" ;;
        --keep-config) KEEP_CONFIG=true ;;
        --no-color) NO_COLOR=true ;;
        --dry-run) DRY_RUN=true ;;
        --list) LIST_ONLY=true ;;
        --) shift; break ;;
        -*) EXIT_CODE=$EXIT_USAGE die "unknown option: $1 (try --help)" ;;
        *)
            [ -n "$PROJECT_ARG" ] && { EXIT_CODE=$EXIT_USAGE die "extra arg: $1"; }
            PROJECT_ARG="$1" ;;
    esac
    shift
done

# Validate enum-shaped options
case "$TERMINAL" in
    warp|iterm2) ;;
    *) EXIT_CODE=$EXIT_USAGE die "--terminal must be warp or iterm2 (got: $TERMINAL)" ;;
esac
case "$WORKTREES" in
    new|existing|none) ;;
    *) EXIT_CODE=$EXIT_USAGE die "--worktrees must be new|existing|none (got: $WORKTREES)" ;;
esac
case "$LAYOUT" in
    tabs|windows|panes) ;;
    *) EXIT_CODE=$EXIT_USAGE die "--layout must be tabs|windows|panes (got: $LAYOUT)" ;;
esac
case "$WARP_MODE" in
    launch-config|tabs) ;;
    *) EXIT_CODE=$EXIT_USAGE die "--warp-mode must be launch-config or tabs (got: $WARP_MODE)" ;;
esac
if [ -n "$BASE_REF" ]; then
    case "$BASE_REF" in
        fresh|head) ;;
        *) EXIT_CODE=$EXIT_USAGE die "--base-ref must be fresh or head (got: $BASE_REF)" ;;
    esac
fi

# ----------------------------------------------------------------------------
# --ui mode: hand off to the web launcher and exit
# ----------------------------------------------------------------------------

if "$USE_UI"; then
    SELF_REAL="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
    UI_LAUNCHER="$(dirname "$SELF_REAL")/praxion-parallel-ui"
    [ -x "$UI_LAUNCHER" ] || { EXIT_CODE=$EXIT_USAGE die "ui launcher missing or not executable at $UI_LAUNCHER"; }
    if [ -n "$PROJECT_ARG" ]; then
        exec "$UI_LAUNCHER" "$PROJECT_ARG"
    else
        exec "$UI_LAUNCHER"
    fi
fi

# ----------------------------------------------------------------------------
# Resolve the project directory
# ----------------------------------------------------------------------------

resolve_project() {
    local raw="${1:-$PWD}"
    local resolved
    if [[ "$raw" = /* ]]; then
        resolved="$raw"
    elif [[ "$raw" == *"/"* ]]; then
        resolved="$(cd "$raw" 2>/dev/null && pwd -P)" || resolved=""
    else
        # Bare name → $PRAXION_DEV_DIR/<name>, with $PWD fallback
        if [ -d "${DEV_DIR}/${raw}" ]; then
            resolved="${DEV_DIR}/${raw}"
        else
            resolved="$(cd "$raw" 2>/dev/null && pwd -P)" || resolved=""
        fi
    fi
    [ -z "$resolved" ] && { EXIT_CODE=$EXIT_PROJECT die "cannot resolve project: $raw"; }
    [ -d "$resolved" ] || { EXIT_CODE=$EXIT_PROJECT die "not a directory: $resolved"; }
    if ! git -C "$resolved" rev-parse --show-toplevel &>/dev/null; then
        EXIT_CODE=$EXIT_PROJECT die "not a git repository: $resolved"
    fi
    git -C "$resolved" rev-parse --show-toplevel
}

PROJECT_DIR="$(resolve_project "$PROJECT_ARG")"
PROJECT_NAME="$(basename "$PROJECT_DIR")"

# Pre-flight: `claude --worktree <name>` needs at least one commit in the
# project so it can resolve a base ref to branch from. A bare `git init`
# with no commits produces an unborn HEAD, and the resulting Claude Code
# error is cryptic ("Failed to resolve base branch 'HEAD': git rev-parse
# failed"). Catch it here with a clear fix recipe.
if [ "$WORKTREES" = "new" ] && ! "$LIST_ONLY"; then
    if ! git -C "$PROJECT_DIR" rev-parse HEAD &>/dev/null; then
        EXIT_CODE=$EXIT_PROJECT die "$(cat <<EOF
project '$PROJECT_NAME' has no commits — \`claude --worktree\` cannot create a worktree
without a base ref to branch from.

Fix (in $PROJECT_DIR):
  git commit --allow-empty -m 'init'

Or run with --worktrees=existing (after creating worktrees by hand) or
--worktrees=none (all sessions share the project root — no isolation).
EOF
)"
    fi
fi

# ----------------------------------------------------------------------------
# --list mode
# ----------------------------------------------------------------------------

if "$LIST_ONLY"; then
    printf "${B}%s${R} worktrees:\n" "$PROJECT_NAME"
    git -C "$PROJECT_DIR" worktree list | sed 's/^/  /'
    exit "$EXIT_OK"
fi

# ----------------------------------------------------------------------------
# Build the session list (name + cwd + initial-prompt per session)
# ----------------------------------------------------------------------------

# Names: explicit --names wins; else synthetic s1..sN; else discovery for `existing`.
NAMES=()
if [ -n "$NAMES_CSV" ]; then
    IFS=',' read -r -a NAMES <<< "$NAMES_CSV"
    # Sanitize: kebab-case, [a-z0-9-] only
    for i in "${!NAMES[@]}"; do
        clean="$(printf "%s" "${NAMES[$i]}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g; s/--*/-/g; s/^-//; s/-$//')"
        [ -z "$clean" ] && { EXIT_CODE=$EXIT_USAGE die "empty name after sanitize at index $i"; }
        NAMES[$i]="$clean"
    done
    COUNT="${#NAMES[@]}"
fi

# Default COUNT
COUNT="${COUNT:-$DEFAULT_SESSIONS}"
if ! [[ "$COUNT" =~ ^[0-9]+$ ]] || [ "$COUNT" -lt 1 ] || [ "$COUNT" -gt "$MAX_SESSIONS" ]; then
    EXIT_CODE=$EXIT_USAGE die "--count must be 1..${MAX_SESSIONS} (got: $COUNT)"
fi

# Panes layout has a tighter cap — even 4 panes on a 13" laptop is dense.
if [ "$LAYOUT" = "panes" ] && [ "$COUNT" -gt 4 ]; then
    EXIT_CODE=$EXIT_USAGE die "--layout=panes supports N=1..4 (got: $COUNT). Use --layout=tabs for N>4."
fi

# Build NAMES + CWDS arrays based on worktree mode
CWDS=()
case "$WORKTREES" in
    new)
        # Synthetic names if --names not provided
        if [ ${#NAMES[@]} -eq 0 ]; then
            for ((i = 1; i <= COUNT; i++)); do
                NAMES+=("s${i}")
            done
        fi
        # In `new` mode, each session's cwd is the project root; claude --worktree
        # handles the cd into the freshly-created worktree.
        for ((i = 0; i < COUNT; i++)); do
            CWDS+=("$PROJECT_DIR")
        done
        ;;
    existing)
        # Discover via porcelain; first entry is the main worktree (skip).
        mapfile -t ALL_WT < <(git -C "$PROJECT_DIR" worktree list --porcelain | awk '/^worktree / {print $2}')
        # Drop the main worktree (which equals $PROJECT_DIR)
        AVAILABLE=()
        for wt in "${ALL_WT[@]}"; do
            [ "$wt" = "$PROJECT_DIR" ] && continue
            AVAILABLE+=("$wt")
        done
        if [ ${#AVAILABLE[@]} -eq 0 ]; then
            EXIT_CODE=$EXIT_PROJECT die "no non-main worktrees in $PROJECT_NAME (try --worktrees new)"
        fi
        # Cap COUNT at available
        if [ "$COUNT" -gt "${#AVAILABLE[@]}" ]; then
            warn "only ${#AVAILABLE[@]} existing worktrees; reducing --count from $COUNT to ${#AVAILABLE[@]}"
            COUNT="${#AVAILABLE[@]}"
        fi
        NAMES=()
        for ((i = 0; i < COUNT; i++)); do
            NAMES+=("$(basename "${AVAILABLE[$i]}")")
            CWDS+=("${AVAILABLE[$i]}")
        done
        ;;
    none)
        warn "--worktrees none: ${COUNT} sessions in the SAME working tree — edit conflicts likely"
        if [ ${#NAMES[@]} -eq 0 ]; then
            for ((i = 1; i <= COUNT; i++)); do NAMES+=("n${i}"); done
        fi
        for ((i = 0; i < COUNT; i++)); do CWDS+=("$PROJECT_DIR"); done
        ;;
esac

# Per-session initial prompts (split on |)
TASKS=()
if [ -n "$TASKS_PIPED" ]; then
    IFS='|' read -r -a TASKS <<< "$TASKS_PIPED"
fi

# Per-session --append-system-prompt strings (split on |)
SYSPROMPTS=()
if [ -n "$SYSPROMPTS_PIPED" ]; then
    IFS='|' read -r -a SYSPROMPTS <<< "$SYSPROMPTS_PIPED"
fi

# Per-session yolo overrides (split on ,). Each element is t/true/1 → true,
# anything else → false. Empty array means "no per-session override; use
# the global --yolo flag value".
YOLOS=()
if [ -n "$YOLOS_CSV" ]; then
    IFS=',' read -r -a YOLOS_RAW <<< "$YOLOS_CSV"
    for v in "${YOLOS_RAW[@]}"; do
        case "$v" in
            t|true|1|TRUE|True) YOLOS+=(true) ;;
            *) YOLOS+=(false) ;;
        esac
    done
fi

# ----------------------------------------------------------------------------
# Build the per-session claude invocation
# ----------------------------------------------------------------------------

# Returns the shell command string to run in each spawned terminal tab.
claude_cmd_for() {
    local idx="$1" name="$2" cwd="$3"
    local parts=("claude")

    case "$WORKTREES" in
        new) parts+=("--worktree" "$name") ;;
        existing|none) ;; # cwd handles it
    esac

    # Per-session yolo: --yolos overrides --yolo when set for this index.
    local yolo_for_session="$YOLO"
    if [ "${#YOLOS[@]}" -gt "$idx" ]; then
        yolo_for_session="${YOLOS[$idx]}"
    fi
    "$yolo_for_session" && parts+=("--dangerously-skip-permissions")

    parts+=("--name" "$(printf "%s/%s" "$PROJECT_NAME" "$name")")

    # Per-session --append-system-prompt (applies before any user input)
    if [ "${#SYSPROMPTS[@]}" -gt "$idx" ] && [ -n "${SYSPROMPTS[$idx]}" ]; then
        parts+=("--append-system-prompt" "${SYSPROMPTS[$idx]}")
    fi

    # Pre-typed task prompt: positional argument to claude
    if [ "${#TASKS[@]}" -gt "$idx" ] && [ -n "${TASKS[$idx]}" ]; then
        parts+=("${TASKS[$idx]}")
    fi

    # Compose with shell quoting that survives YAML embedding and AppleScript
    local q=""
    for p in "${parts[@]}"; do
        q+="$(printf "%q " "$p")"
    done
    printf "cd %q && %s" "$cwd" "$q"
}

color_for() {
    local idx="$1" backend="$2"
    "$NO_COLOR" && { printf ""; return; }
    local mod=$((idx % 6))
    case "$backend" in
        warp) printf "%s" "${WARP_COLORS[$mod]}" ;;
        iterm|iterm2) printf "%s" "${ITERM_RGB[$mod]}" ;;
    esac
}

# ----------------------------------------------------------------------------
# Dry-run output
# ----------------------------------------------------------------------------

print_plan() {
    printf "${B}Plan:${R} %d session(s) in %s · backend=%s · layout=%s · yolo=%s\n" \
        "$COUNT" "$PROJECT_NAME" "$TERMINAL" "$LAYOUT" "$YOLO"
    "$YOLO" && warn "AUTO-APPROVE: every session will run with --dangerously-skip-permissions"
    if [ -n "$BASE_REF" ] && [ "$WORKTREES" = "new" ]; then
        info "  worktree base-ref: $BASE_REF (writes settings overlay)"
    fi
    printf "\n"
    for ((i = 0; i < COUNT; i++)); do
        printf "  ${B}#%d${R}  name=%-10s  color=%-7s  cwd=%s\n" \
            "$((i+1))" "${NAMES[$i]}" \
            "$(color_for "$i" "$TERMINAL")" \
            "${CWDS[$i]/$HOME/~}"
        printf "         %s\n" "$(claude_cmd_for "$i" "${NAMES[$i]}" "${CWDS[$i]}")"
    done
}

if "$DRY_RUN"; then
    print_plan
    exit "$EXIT_OK"
fi

# ----------------------------------------------------------------------------
# Apply --base-ref via Claude Code settings overlay
# ----------------------------------------------------------------------------

# Claude Code reads worktree.baseRef from ~/.claude/settings.json. We only set
# this when the user passes --base-ref. A non-zero risk: this is process-global,
# so a concurrent unrelated `claude --worktree` will also pick it up until the
# spawn finishes. The window is small (seconds), and the value is restored.

settings_overlay_apply() {
    [ -z "$BASE_REF" ] && return 0
    [ "$WORKTREES" != "new" ] && return 0
    local settings="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/settings.json"
    [ -f "$settings" ] || { warn "no settings.json at $settings; --base-ref ignored"; return 0; }
    python3 - "$settings" "$BASE_REF" <<'PY'
import json, os, sys
path, value = sys.argv[1], sys.argv[2]
with open(path) as f: data = json.load(f)
data.setdefault("worktree", {})["baseRef"] = value
tmp = path + ".praxion-parallel.bak"
os.rename(path, tmp)
try:
    with open(path, "w") as f: json.dump(data, f, indent=2)
except Exception:
    os.rename(tmp, path); raise
PY
}

settings_overlay_restore() {
    [ -z "$BASE_REF" ] && return 0
    [ "$WORKTREES" != "new" ] && return 0
    local settings="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/settings.json"
    local bak="${settings}.praxion-parallel.bak"
    [ -f "$bak" ] && mv "$bak" "$settings" 2>/dev/null || true
}

# Schedule a DELAYED restore so the overlay survives until the spawned terminals
# actually start `claude --worktree`. Without the delay, the trap fires when the
# bash script exits — milliseconds later — and the spawned claude processes read
# the already-restored settings.
#
# CRITICAL: redirect the subshell's stdout/stderr to /dev/null. Otherwise the
# parent's pipes stay open for the duration of the sleep, blocking any caller
# (e.g., the Python launcher's subprocess.run) from seeing the bash script
# actually finish. This is the root cause of the "TypeError: Object of type
# bytes is not JSON serializable" error users hit: subprocess.run waits for
# the pipe to close, hits its own timeout, and TimeoutExpired.{stdout,stderr}
# come back as bytes.
schedule_delayed_overlay_restore() {
    [ -z "$BASE_REF" ] && return 0
    [ "$WORKTREES" != "new" ] && return 0
    # 15 seconds: enough for Warp's launch-config to materialize tabs and for
    # claude --worktree to read settings.json before the restore fires.
    ( sleep 15 && settings_overlay_restore ) >/dev/null 2>&1 &
    disown
}

# ----------------------------------------------------------------------------
# Warp backend — generate a Launch Configuration and `open warp://launch/<id>`
# ----------------------------------------------------------------------------

spawn_warp() {
    command -v open &>/dev/null || { EXIT_CODE=$EXIT_TERMINAL die "no 'open' command (macOS only)"; }
    settings_overlay_apply

    # Activate Warp before sending any URL so cold-start races are minimized.
    # `open -a Warp` returns immediately; the small sleep gives Warp's URL
    # handler a moment to be ready when Warp wasn't already running.
    open -a Warp 2>/dev/null || true
    sleep 0.4

    if [ "$WARP_MODE" = "tabs" ]; then
        spawn_warp_tabs
    else
        spawn_warp_launch_config
    fi
}

# Mode A — Launch Configuration (default).
# Autonomous: writes a YAML, opens warp://launch/<name>. Subject to upstream
# Warp bug #9007 (commands silently dropped on URL launch); a manual-fallback
# block is always printed so the user can recover if nothing visibly happens.
spawn_warp_launch_config() {
    mkdir -p "$WARP_LC_DIR" || { EXIT_CODE=$EXIT_TERMINAL die "cannot create $WARP_LC_DIR"; }

    local stamp lc_name lc_path
    stamp="$(date +%Y%m%d-%H%M%S)"
    lc_name="praxion-parallel-${PROJECT_NAME}-${stamp}"
    lc_path="${WARP_LC_DIR}/${lc_name}.yaml"

    {
        printf -- "---\n"
        printf "name: %s\n" "$lc_name"
        printf "windows:\n"
        # YAML indent shape:
        #   windows:
        #     - tabs:                  (dash col 2, key col 4)
        #         - title: ...         (dash col 6, key col 8)
        #           cwd: ...           (col 8, sibling of title)
        #           commands:          (col 8)
        #             - exec: ...      (col 10)
        case "$LAYOUT" in
            tabs)
                printf "  - tabs:\n"
                for ((i = 0; i < COUNT; i++)); do
                    _emit_warp_tab "$i" "          " "        - "
                done ;;
            windows)
                for ((i = 0; i < COUNT; i++)); do
                    printf "  - tabs:\n"
                    _emit_warp_tab "$i" "          " "        - "
                done ;;
            panes)
                # One window, one tab, N panes inside the tab's `layout:` block.
                printf "  - tabs:\n"
                printf "        - title: %s\n" "$(_yaml_escape "${NAMES[0]} · ${PROJECT_NAME} (${COUNT} panes)")"
                printf "          layout:\n"
                _emit_warp_panes_layout "$COUNT" "            " ;;
        esac
    } > "$lc_path" || { EXIT_CODE=$EXIT_SPAWN die "failed to write $lc_path"; }

    info "Warp launch config: ${lc_path/$HOME/~}"
    info "Sending: open \"warp://launch/${lc_name}\""

    if ! open "warp://launch/${lc_name}" 2>/dev/null; then
        EXIT_CODE=$EXIT_SPAWN die "open warp://launch/${lc_name} failed (is Warp installed?)"
    fi

    schedule_delayed_overlay_restore

    # Cleanup at 30s (was 5s). Warp can be slow to scan after a cold-start /
    # post-update activation; 30s is the empirical safety margin.
    # Redirect to /dev/null so the disowned subshell doesn't inherit (and hold
    # open) stdout/stderr — otherwise callers that pipe the script (like the
    # Python launcher's subprocess.run) hang waiting for the pipe to close.
    if ! "$KEEP_CONFIG"; then
        ( sleep 30 && rm -f "$lc_path" ) >/dev/null 2>&1 &
        disown
    fi

    printf "\n"
    printf "${Y}If nothing opened in Warp:${R}\n"
    printf "  · Re-run manually:  ${B}open \"warp://launch/%s\"${R}\n" "$lc_name"
    printf "  · Or open from Warp's Command Palette (⌘P) → \"Launch Configuration\" → \"%s\"\n" "$lc_name"
    printf "  · YAML stays at ${B}%s${R}%s\n" "${lc_path/$HOME/~}" "$($KEEP_CONFIG && printf "" || printf " for 30s")"
    printf "  · Known Warp upstream bug #9007: commands may not run via URL launch.\n"
    printf "    Workaround: switch to ${B}--warp-mode=tabs${R} (opens tabs at the right\n"
    printf "    cwd, prints the claude command for you to paste-and-Enter).\n\n"
    info "Sent launch URL for ${COUNT} session(s) to Warp."
}

# Mode B — per-tab URLs (reliable but not fully autonomous).
# Opens N tabs at the right cwds via warp://action/new_tab?path=, then prints
# the claude command for each tab. The user pastes-and-Enters in each tab.
spawn_warp_tabs() {
    info "Opening ${COUNT} Warp tab(s) at target cwds (Warp bug #9007 workaround)."
    printf "\n"
    for ((i = 0; i < COUNT; i++)); do
        local cwd="${CWDS[$i]}"
        local cmd
        cmd="$(claude_cmd_for "$i" "${NAMES[$i]}" "$cwd")"
        local enc_cwd
        enc_cwd="$(_url_encode "$cwd")"

        local url
        if [ "$i" -eq 0 ] || [ "$LAYOUT" = "windows" ]; then
            url="warp://action/new_window?path=${enc_cwd}"
        else
            url="warp://action/new_tab?path=${enc_cwd}"
        fi

        if ! open "$url" 2>/dev/null; then
            warn "open '$url' failed for tab $((i+1)); skipping."
            continue
        fi
        # Small pacing so tabs open in order; Warp's URL handler ignores
        # rapid-fire URLs occasionally.
        sleep 0.3

        printf "  ${B}#%d${R}  %s\n    paste-and-Enter:  ${B}%s${R}\n\n" \
            "$((i+1))" "${NAMES[$i]}" "$cmd"
    done
    info "Opened ${COUNT} tab(s). Paste the matching command into each."
}

_url_encode() {
    python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1"
}

# Emit one tab block to stdout. Prefix style:
#   - first line:  "<list_prefix>title: ..."
#   - body lines:  "<indent>color: ..." etc.
_emit_warp_tab() {
    local i="$1" indent="$2" list_prefix="$3"
    local title="${NAMES[$i]} · ${PROJECT_NAME}"
    local color cwd cmd
    color="$(color_for "$i" "warp")"
    cwd="${CWDS[$i]}"
    cmd="$(claude_cmd_for "$i" "${NAMES[$i]}" "$cwd")"

    printf "%stitle: %s\n" "$list_prefix" "$(_yaml_escape "$title")"
    [ -n "$color" ] && printf "%scolor: %s\n" "$indent" "$color"
    printf "%scwd: %s\n" "$indent" "$(_yaml_escape "$cwd")"
    printf "%scommands:\n" "$indent"
    printf "%s  - exec: %s\n" "$indent" "$(_yaml_escape "$cmd")"
}

# Emit a leaf pane block (cwd + commands) at the given indent.
_emit_warp_pane_leaf() {
    local i="$1" indent="$2"
    local cwd="${CWDS[$i]}"
    local cmd
    cmd="$(claude_cmd_for "$i" "${NAMES[$i]}" "$cwd")"
    printf "%scwd: %s\n" "$indent" "$(_yaml_escape "$cwd")"
    printf "%scommands:\n" "$indent"
    printf "%s  - exec: %s\n" "$indent" "$(_yaml_escape "$cmd")"
}

# Emit a nested `split_direction` + `panes` block. Tilings:
#   N=2: vertical (left/right) — 1 split
#   N=3: vertical, then horizontal of right half — 1 left, 2 stacked right
#   N=4: vertical, then horizontal of both halves — 2x2 grid
_emit_warp_panes_layout() {
    local n="$1" indent="$2"
    local sub="${indent}      "  # leaf indent inside `- ` list item

    case "$n" in
        1)
            # Single pane: degenerate to a tab without split. Promote pane#0 to leaf fields.
            _emit_warp_pane_leaf 0 "$indent" ;;
        2)
            printf "%ssplit_direction: vertical\n" "$indent"
            printf "%spanes:\n" "$indent"
            printf "%s- " "${indent}  "; _emit_warp_pane_leaf_inline 0 "${indent}    "
            printf "%s- " "${indent}  "; _emit_warp_pane_leaf_inline 1 "${indent}    " ;;
        3)
            printf "%ssplit_direction: vertical\n" "$indent"
            printf "%spanes:\n" "$indent"
            printf "%s- " "${indent}  "; _emit_warp_pane_leaf_inline 0 "${indent}    "
            printf "%s- split_direction: horizontal\n" "${indent}  "
            printf "%s  panes:\n" "${indent}  "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 1 "${indent}        "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 2 "${indent}        " ;;
        4)
            printf "%ssplit_direction: vertical\n" "$indent"
            printf "%spanes:\n" "$indent"
            printf "%s- split_direction: horizontal\n" "${indent}  "
            printf "%s  panes:\n" "${indent}  "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 0 "${indent}        "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 1 "${indent}        "
            printf "%s- split_direction: horizontal\n" "${indent}  "
            printf "%s  panes:\n" "${indent}  "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 2 "${indent}        "
            printf "%s  - " "${indent}    "; _emit_warp_pane_leaf_inline 3 "${indent}        " ;;
    esac
}

# Emit a leaf pane inline starting from the cwd: line (the dash + space prefix
# is already printed by the caller; this just emits cwd: and following keys).
_emit_warp_pane_leaf_inline() {
    local i="$1" indent="$2"
    local cwd="${CWDS[$i]}"
    local cmd
    cmd="$(claude_cmd_for "$i" "${NAMES[$i]}" "$cwd")"
    printf "cwd: %s\n" "$(_yaml_escape "$cwd")"
    printf "%scommands:\n" "$indent"
    printf "%s  - exec: %s\n" "$indent" "$(_yaml_escape "$cmd")"
}

# Single-quoted YAML scalar — safe for arbitrary strings (escape single quotes
# by doubling them, per YAML 1.2).
_yaml_escape() {
    python3 -c "import sys; s=sys.argv[1]; print(\"'\" + s.replace(\"'\", \"''\") + \"'\")" "$1"
}

# ----------------------------------------------------------------------------
# iTerm2 backend — AppleScript via osascript
# ----------------------------------------------------------------------------

spawn_iterm2() {
    command -v osascript &>/dev/null || { EXIT_CODE=$EXIT_TERMINAL die "no osascript (macOS only)"; }
    osascript -e 'tell application "System Events" to (name of processes) contains "iTerm2"' >/dev/null 2>&1 || true

    settings_overlay_apply

    local script
    script="$(_build_iterm_script)"
    if ! osascript -e "$script" >/dev/null; then
        EXIT_CODE=$EXIT_SPAWN die "osascript failed (is iTerm2 installed?)"
    fi

    schedule_delayed_overlay_restore

    info "Launched ${COUNT} session(s) in iTerm2."
}

# iTerm2 escape sequence to set the tab color of the current session.
# Format: ESC ] 6 ; 1 ; bg ; red ; brightness ; <r> BEL  (one per channel).
# Reference: https://iterm2.com/documentation-escape-codes.html (Set Color)
_iterm_color_seq() {
    local rgb="$1"
    [ -z "$rgb" ] && return
    local r g b
    IFS=';' read -r r g b <<< "$rgb"
    printf '\\033]6;1;bg;red;brightness;%s\\a\\033]6;1;bg;green;brightness;%s\\a\\033]6;1;bg;blue;brightness;%s\\a' \
        "$r" "$g" "$b"
}

# AppleScript escape: double-quote-safe via backslash escaping.
_as_escape() {
    python3 -c 'import sys; s=sys.argv[1]; print(s.replace("\\","\\\\").replace("\"","\\\""))' "$1"
}

# Generate the shell command for session #i, including the OSC title and
# OSC-6 tab color prelude. Used by both tabs and panes layouts.
_iterm_full_cmd() {
    local i="$1"
    local title cmd rgb color_seq
    title="${NAMES[$i]} · ${PROJECT_NAME}"
    cmd="$(claude_cmd_for "$i" "${NAMES[$i]}" "${CWDS[$i]}")"
    rgb="$(color_for "$i" "iterm")"
    color_seq="$(_iterm_color_seq "$rgb")"
    printf 'printf %s; printf %s; %s' \
        "'\\033]0;$(_as_escape "$title")\\a'" \
        "'${color_seq}'" \
        "$cmd"
}

_build_iterm_script() {
    case "$LAYOUT" in
        tabs)    _build_iterm_tabs ;;
        windows) _build_iterm_windows ;;
        panes)   _build_iterm_panes ;;
    esac
}

# Layout=tabs: one window, N tabs.
_build_iterm_tabs() {
    local lines=()
    lines+=('tell application "iTerm"')
    lines+=('  activate')
    lines+=('  set newWindow to (create window with default profile)')

    local i
    for ((i = 0; i < COUNT; i++)); do
        local full_cmd
        full_cmd="$(_iterm_full_cmd "$i")"

        if [ "$i" -eq 0 ]; then
            lines+=("  tell current session of newWindow")
            lines+=("    write text \"$(_as_escape "$full_cmd")\"")
            lines+=("  end tell")
        else
            lines+=("  tell newWindow")
            lines+=("    create tab with default profile")
            lines+=("  end tell")
            lines+=("  tell current session of newWindow")
            lines+=("    write text \"$(_as_escape "$full_cmd")\"")
            lines+=("  end tell")
        fi
    done

    lines+=('end tell')
    printf "%s\n" "${lines[@]}"
}

# Layout=windows: N separate windows.
_build_iterm_windows() {
    local lines=()
    lines+=('tell application "iTerm"')
    lines+=('  activate')
    local i
    for ((i = 0; i < COUNT; i++)); do
        local full_cmd
        full_cmd="$(_iterm_full_cmd "$i")"
        lines+=("  set w${i} to (create window with default profile)")
        lines+=("  tell current session of w${i}")
        lines+=("    write text \"$(_as_escape "$full_cmd")\"")
        lines+=("  end tell")
    done
    lines+=('end tell')
    printf "%s\n" "${lines[@]}"
}

# Layout=panes: one window, one tab, N rectangular split panes (N=1..4).
# Split convention: "vertically" = vertical divider line (left|right),
# "horizontally" = horizontal divider line (top/bottom).
#
# Tilings (s1 is the initial session, splits return new sessions):
#   N=2:  s1 | s2                                    (vertical split of s1)
#   N=3:  s1 | s2/s3                                 (vert(s1)=s2; horiz(s2)=s3)
#   N=4:  s1/s3 | s2/s4   (2x2)                      (vert(s1)=s2; horiz(s1)=s3; horiz(s2)=s4)
#
# Implementation note: AppleScript's inline form
#   `set s2 to (tell s1 to split vertically with default profile command "...")`
# is rejected by the AppleScript compiler (the `command` token after `to`
# confuses the grammar). The block form
#   `tell s1 \n  set s2 to (split vertically with default profile command "...") \n end tell`
# is the only shape that parses cleanly.
_build_iterm_panes() {
    local lines=()
    lines+=('tell application "iTerm"')
    lines+=('  activate')
    lines+=('  set w to (create window with default profile)')
    lines+=('  set s1 to current session of w')

    # First session's command runs in s1 via write text (s1 was created with
    # no command parameter).
    lines+=("  tell s1")
    lines+=("    write text \"$(_as_escape "$(_iterm_full_cmd 0)")\"")
    lines+=("  end tell")

    # Emit the script body to date, then append the splits and the closing tell.
    # Done in two phases to stay bash-3.2 compatible (no nameref/mapfile).
    printf "%s\n" "${lines[@]}"

    case "$COUNT" in
        1) ;;
        2)
            _iterm_split_block 1 s1 s2 vertically ;;
        3)
            _iterm_split_block 1 s1 s2 vertically
            _iterm_split_block 2 s2 s3 horizontally ;;
        4)
            _iterm_split_block 1 s1 s2 vertically
            _iterm_split_block 2 s1 s3 horizontally
            _iterm_split_block 3 s2 s4 horizontally ;;
    esac

    printf "end tell\n"
}

# Emit a `tell <parent> ... split ... command "..." ... end tell` block to stdout
# as three lines (one per array entry the caller will use). Bash-3.2 compatible
# (no `local -n` nameref, no `mapfile`).
# Args: command-index parent-session new-session direction
_iterm_split_block() {
    local cmd_idx="$1" parent="$2" newvar="$3" direction="$4"
    local cmd
    cmd="$(_iterm_full_cmd "$cmd_idx")"
    printf "  tell %s\n" "$parent"
    printf "    set %s to (split %s with default profile command \"%s\")\n" \
        "$newvar" "$direction" "$(_as_escape "$cmd")"
    printf "  end tell\n"
}

# ----------------------------------------------------------------------------
# Dispatch
# ----------------------------------------------------------------------------

print_plan
printf "\n"
"$YOLO" && warn "AUTO-APPROVE active — sessions will run unsupervised. You asked for this."
printf "\n"

case "$TERMINAL" in
    warp)   spawn_warp ;;
    iterm2) spawn_iterm2 ;;
esac

settings_overlay_restore
exit "$EXIT_OK"
